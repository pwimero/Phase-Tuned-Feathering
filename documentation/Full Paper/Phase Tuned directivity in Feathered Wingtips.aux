\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Mutation effectiveness. The scatter compares the geometry mutation magnitude index against the validated target RMSE improvement, showing that larger geometry variations do not necessarily guarantee proportional acoustic gain.}}{21}{figure.7}\protected@file@percent }
