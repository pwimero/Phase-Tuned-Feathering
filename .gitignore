# =============================================================================
# Phase-Tuned-Feathering: publication-ready .gitignore
# Repository: https://github.com/pwimero/Phase-Tuned-Feathering
# =============================================================================

# Python caches and artifacts
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# LaTeX build artifacts
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv
*.log

# Keep LaTeX PDFs (manuscript, figures)
!*.pdf

# Data files (large outputs)
*.npy
*.npz
*.pkl
*.pickle
*.h5
*.hdf5
*.mat
*.pt
*.pth
*.ckpt
*.parquet
*.feather

# Temporary files
*.tmp
*.temp
*.bak
*.old
*.orig
tmp/
temp/
scratch/
local/
runs/
run_*/
wandb/
mlruns/

# Secrets and credentials
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.*
credentials.*
token.*
tokens.*

# Todo / notes (keep private)
todolist
todo
TODO
TODO.md
notes/
draft_notes/

# =============================================================================
# Keep public source code and reproducibility infrastructure
# =============================================================================

!src/
!src/**
!scripts/
!scripts/**
!tests/
!tests/**
!FWA-Bench-0/
!FWA-Bench-0/**
!Fusion/
!Fusion/**

# Keep documentation but exclude LaTeX build files
!documentation/
!documentation/**
documentation/**/*.aux
documentation/**/*.bbl
documentation/**/*.blg
documentation/**/*.log
documentation/**/*.out
documentation/**/*.synctex.gz
documentation/**/*.toc

# Keep outputs but exclude binary/large files
!outputs/
!outputs/README.md
!outputs/**/*.json
!outputs/**/*.csv
!outputs/**/*.txt
!outputs/**/*.yaml
!outputs/**/*.yml
!outputs/**/*.svg
!outputs/**/*.png
!outputs/**/*.pdf

# Exclude heavy binary outputs
outputs/**/*.npy
outputs/**/*.npz
outputs/**/*.pkl
outputs/**/*.pickle
outputs/**/*.h5
outputs/**/*.hdf5
outputs/**/*.mat
outputs/**/*.pt
outputs/**/*.pth
outputs/**/*.ckpt

# Exclude raw optimization dumps
outputs/raw/
outputs/raw_results/
outputs/raw_outputs/
outputs/checkpoints/
outputs/population*
outputs/generations/
outputs/full_runs/
outputs/debug/
outputs/tmp/
outputs/temp/

# Exclude Fusion generated CAD binaries
Fusion/**/*.f3d
Fusion/**/*.f3z
Fusion/**/*.step
Fusion/**/*.stp
Fusion/**/*.iges
Fusion/**/*.igs
Fusion/**/*.sat
Fusion/**/*.obj
Fusion/**/*.stl
Fusion/**/.vscode/

# Keep project config files
!pyproject.toml
!README.md
!LICENSE
!CITATION.cff